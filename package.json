{
  "name": "vouch",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ngrok = Start-Process ngrok -ArgumentList 'http','--url=liberal-gull-quietly.ngrok-free.app','3000' -PassThru -WindowStyle Hidden; $stripe = Start-Process stripe -ArgumentList 'listen','--forward-to','localhost:3000/api/stripe/webhooks' -PassThru -WindowStyle Hidden; try { next dev } finally { foreach ($process in @($ngrok, $stripe)) { if ($process -and -not $process.HasExited) { Stop-Process -Id $process.Id } } }\"",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "typegen": "next typegen",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:target": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "validate:contracts": "node scripts/validate-contracts.mjs",
    "validate": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm prisma:validate && corepack pnpm validate:contracts && corepack pnpm test",
    "validate:all": "corepack pnpm validate && corepack pnpm test:e2e",
    "clean": "rimraf .next coverage test-results playwright-report"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@clerk/nextjs": "7.5.2",
    "@hookform/resolvers": "5.4.0",
    "@neondatabase/serverless": "1.1.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-accordion": "1.2.13",
    "@radix-ui/react-alert-dialog": "1.1.16",
    "@radix-ui/react-avatar": "1.1.12",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-collapsible": "1.1.13",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-popover": "1.1.16",
    "@radix-ui/react-progress": "1.1.9",
    "@radix-ui/react-radio-group": "1.4.0",
    "@radix-ui/react-scroll-area": "1.2.11",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-switch": "1.3.0",
    "@radix-ui/react-tabs": "1.1.14",
    "@radix-ui/react-toggle": "1.1.11",
    "@radix-ui/react-toggle-group": "1.1.12",
    "@radix-ui/react-tooltip": "1.2.9",
    "@stripe/stripe-js": "9.8.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "input-otp": "1.4.2",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.78.0",
    "server-only": "0.0.1",
    "shadcn": "4.11.0",
    "sonner": "2.0.7",
    "stripe": "22.2.0",
    "tailwind-merge": "3.6.0",
    "vaul": "1.1.2",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@clerk/testing": "2.1.1",
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.20",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hook-form": "0.3.1",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "rimraf": "6.1.3",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  }
}
