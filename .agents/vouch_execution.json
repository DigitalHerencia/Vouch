{
  "id": "vouch.execution",
  "project": "Vouch",
  "authority": "source-of-truth",
  "updated": "2026-05-24",
  "status": "active",
  "purpose": "Execution contract for agent implementation, audit, validation, and launch sequencing of the Vouch MVP.",
  "northStar": {
    "productDefinition": "Deterministic payment coordination infrastructure for real-world commitments.",
    "coreRule": "Both participants confirm presence inside the confirmation window before capture can proceed. Anything else resolves to provider-backed non-capture, cancellation, expiration, or refund according to Stripe state.",
    "finalInvariant": "Outcome follows system state.",
    "forbiddenSurfaces": [
      "marketplace",
      "broker",
      "scheduler",
      "messaging",
      "chat",
      "public_profiles",
      "provider_discovery",
      "service_listings",
      "categories",
      "search",
      "browse",
      "ratings",
      "reviews",
      "disputes",
      "claims",
      "appeals",
      "evidence",
      "screenshots_as_proof",
      "arbitration",
      "mediation",
      "manual_settlement",
      "manual_release",
      "manual_refund_award",
      "manual_confirmation_rewrite",
      "support_override",
      "admin_outcome_decision",
      "force_release",
      "force_refund",
      "alternate_payout_rail"
    ]
  },
  "authorityModel": {
    "clerk": {
      "owns": ["authentication_truth", "sign_in", "sign_up", "sessions", "auth_provider_lifecycle_events"],
      "doesNotOwn": ["workflow_truth", "payment_truth", "settlement_eligibility"]
    },
    "stripe": {
      "owns": ["payment_truth", "checkout", "payment_method_collection", "manual_capture_payment_intents", "authorization_state", "capturability", "capture_result", "cancellation_state", "refund_state", "connect_onboarding", "kyc_compliance_collection", "payout_capability_state", "payout_execution", "provider_payment_state"],
      "doesNotOwn": ["workflow_truth", "presence_confirmation_truth", "vouch_lifecycle_meaning"]
    },
    "vouch": {
      "owns": ["workflow_truth", "local_user_record", "terms_acceptance_record", "vouch_lifecycle_state", "participant_role_state", "appointment_timestamp", "confirmation_window", "bilateral_confirmation_truth", "settlement_eligibility_decision", "safe_provider_reference_mirror", "audit_ledger", "archive_visibility", "internal_recovery_state"],
      "doesNotOwn": ["raw_payment_credentials", "raw_bank_data", "raw_identity_documents", "raw_provider_truth", "marketplace_discovery", "user_messaging", "dispute_resolution"]
    }
  },
  "stateModel": {
    "vouchLifecycle": {
      "canonical": ["draft", "committed", "sent", "accepted", "authorized", "confirmable", "completed", "expired"],
      "terminal": ["completed", "expired"],
      "immutableFrom": "committed",
      "forbiddenLifecycleValues": ["pending", "active", "refunded", "canceled", "failed", "voided", "settled", "provider_restricted", "archived"]
    },
    "participantRoles": {
      "canonical": ["merchant", "customer"],
      "paymentAliases": { "merchant": "payee", "customer": "payer" },
      "rule": "Roles are scoped to a Vouch, not global account type."
    },
    "confirmation": {
      "allowedMethods": ["code_exchange", "offline_code_exchange"],
      "forbiddenMethods": ["gps", "manual", "system", "admin", "support", "screenshot", "evidence"],
      "aggregateStatuses": ["none_confirmed", "merchant_confirmed", "customer_confirmed", "both_confirmed"],
      "settlementEligibleOnlyWhen": "both_confirmed"
    },
    "separateAxes": {
      "paymentStatus": ["not_started", "checkout_created", "requires_payment_method", "requires_capture", "authorized", "capture_processing", "captured", "canceled", "expired", "failed"],
      "settlementStatus": ["pending", "non_capture_pending", "non_captured", "capture_pending", "captured", "refund_pending", "refunded", "provider_blocked", "failed"],
      "archiveStatus": ["active", "archived"],
      "recoveryStatus": ["normal", "recovery_required", "recovery_in_progress", "recovered", "recovery_failed"],
      "webhookStatus": ["received", "processed", "ignored", "failed"]
    }
  },
  "canonicalRoutes": {
    "public": ["/", "/pricing", "/faq", "/legal/terms", "/legal/privacy", "/checkout/success"],
    "auth": ["/sign-in", "/sign-up"],
    "tenant": ["/dashboard", "/vouches/new", "/vouches/new/confirm", "/vouches/[vouchId]"],
    "api": ["/api/clerk/webhooks", "/api/stripe/webhooks"],
    "forbidden": ["/setup", "/settings", "/settings/payment", "/settings/payout", "/settings/verification", "/readiness", "/account", "/profile", "/admin", "/admin/settlement", "/messages", "/disputes", "/claims", "/appeals", "/evidence", "/reviews", "/ratings", "/search", "/browse", "/providers", "/marketplace"]
  },
  "layerPipelines": {
    "protectedFetcher": ["authenticate", "authorize", "minimal_select", "map_to_dto", "cache_policy", "transport_safe_return"],
    "serverAction": ["authenticate", "authorize", "zod_validate", "transaction_or_provider_operation", "audit_event", "revalidate_or_redirect", "typed_result"],
    "webhook": ["read_raw_body", "verify_signature", "parse_event_envelope", "classify_event_type", "record_provider_event_id", "process_idempotently", "reconcile_only_valid_forward_movement", "write_audit_event_if_transition_occurred", "provider_compatible_response"],
    "settlement": ["load_vouch_workflow_state", "load_local_payment_state", "retrieve_current_stripe_payment_intent", "verify_bilateral_confirmation_truth", "verify_provider_capturability", "capture_cancel_or_refund_with_durable_idempotency_key", "persist_provider_backed_result", "write_audit_event", "revalidate_affected_surfaces"]
  },
  "stripe": {
    "merchantFeeFlow": {
      "providerAccount": "platform",
      "object": "checkout_session_or_payment_intent",
      "connectDestinationCharge": false,
      "applicationFeeAmountForFee": false,
      "requiredBeforeLifecycle": "committed"
    },
    "customerAuthorizationFlow": {
      "hostedBy": "checkout_session",
      "object": "payment_intent",
      "captureMethod": "manual",
      "amountIncludesMerchantFee": false,
      "captureOnlyAfter": "bilateral_confirmation_and_provider_retrieval"
    },
    "webhookEvents": {
      "merchantFee": ["checkout.session.completed", "checkout.session.expired", "payment_intent.succeeded", "payment_intent.payment_failed"],
      "customerAuthorization": ["checkout.session.completed", "checkout.session.expired", "payment_intent.succeeded", "payment_intent.canceled", "payment_intent.payment_failed", "payment_intent.amount_capturable_updated"],
      "connect": ["account.updated"]
    },
    "corrections": [
      "Do not use payment_intent.requires_capture as a webhook event name; requires_capture is a PaymentIntent status.",
      "Do not model settled or voided as Vouch lifecycle states.",
      "Do not expose customer authorization before merchant fee success."
    ]
  },
  "implementationBacklog": [
    {
      "id": "MVP-001",
      "title": "Install governance artifacts",
      "status": "ready",
      "layer": "agents",
      "objective": "Place revised AGENTS.md, intent, payment architecture, governance YAML, and execution JSON into the repository.",
      "acceptanceCriteria": ["Contracts use canonical lifecycle states.", "Forbidden product surfaces are explicit.", "Stripe webhook event names are valid.", "Merchant fee and customer authorization are separate flows."],
      "validation": ["pnpm validate:contracts"]
    },
    {
      "id": "MVP-002",
      "title": "Normalize state axes",
      "status": "pending",
      "layer": "database",
      "objective": "Separate Vouch lifecycle from payment, settlement, archive, recovery, and webhook states.",
      "acceptanceCriteria": ["Vouch lifecycle contains only eight approved values.", "Provider/payment states do not live in VouchStatus.", "Duplicate confirmations and webhook events are impossible at database level."],
      "validation": ["pnpm prisma:validate", "pnpm typecheck"]
    },
    {
      "id": "MVP-003",
      "title": "Implement Stripe integration surface",
      "status": "pending",
      "layer": "provider_integration",
      "objective": "Implement platform merchant fee checkout and customer manual-capture checkout as separate provider flows.",
      "acceptanceCriteria": ["Merchant fee is platform-owned.", "Customer PaymentIntent uses manual capture.", "Capture/cancel/refund are idempotent.", "Provider state is retrieved before settlement operations."],
      "validation": ["pnpm typecheck", "pnpm test"]
    },
    {
      "id": "MVP-004",
      "title": "Implement confirmation and settlement guards",
      "status": "pending",
      "layer": "domain_actions",
      "objective": "Ensure bilateral in-window confirmation is the only settlement eligibility path.",
      "acceptanceCriteria": ["One-sided confirmation never captures.", "Duplicate confirmation is rejected transactionally.", "Expired unconfirmed Vouches cancel or mirror provider state.", "Audit events are written for important transitions."],
      "validation": ["pnpm test", "pnpm test:e2e"]
    },
    {
      "id": "MVP-005",
      "title": "Run launch validation",
      "status": "pending",
      "layer": "validation",
      "objective": "Prove contracts, schema, types, tests, and E2E flow satisfy the MVP loop.",
      "acceptanceCriteria": ["No forbidden product surface remains.", "No unilateral capture is possible.", "Webhook duplicate delivery is idempotent.", "Browser return is not payment truth."],
      "validation": ["pnpm prisma:validate", "pnpm validate:contracts", "pnpm lint", "pnpm typecheck", "pnpm test", "pnpm test:e2e", "pnpm validate"]
    }
  ],
  "qualityGates": {
    "contracts": { "command": "pnpm validate:contracts", "requiredBefore": ["merge", "handoff_update", "launch"] },
    "prisma": { "command": "pnpm prisma:validate", "requiredBefore": ["db_migration", "launch"] },
    "lint": { "command": "pnpm lint", "requiredBefore": ["commit", "launch"] },
    "typecheck": { "command": "pnpm typecheck", "requiredBefore": ["commit", "launch"] },
    "unit": { "command": "pnpm test", "requiredBefore": ["launch"] },
    "e2e": { "command": "pnpm test:e2e", "requiredBefore": ["launch"] },
    "full": { "command": "pnpm validate", "requiredBefore": ["release_candidate"] }
  },
  "launchReadiness": {
    "currentStatus": "not_complete_until_validated_against_repo",
    "minimumFunctionalLoop": ["merchant_account_created", "merchant_terms_accepted", "merchant_connect_ready", "vouch_draft_created", "merchant_fee_paid", "vouch_committed_immutable", "authorization_link_available", "customer_account_created_or_authenticated", "customer_terms_accepted", "manual_capture_payment_intent_authorized", "confirmation_window_open", "merchant_confirmation_written", "customer_confirmation_written", "bilateral_confirmation_locked", "stripe_payment_intent_retrieved", "capture_idempotently_executed_if_capturable", "audit_events_written", "dashboard_detail_updated"],
    "hardBlockers": ["forbidden_product_surface_present", "manual_settlement_path_present", "unilateral_capture_possible", "raw_sensitive_provider_storage_present", "provider_retrieve_before_capture_missing", "webhook_idempotency_missing", "terms_acceptance_not_persisted_in_vouch_db", "canonical_lifecycle_not_enforced", "payment_provider_states_inside_vouch_lifecycle", "app_route_contains_provider_or_db_business_logic"]
  }
}

