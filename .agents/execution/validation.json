{
  "version": 2,
  "project": "Vouch",
  "status": "source-governed-validation-required",
  "source_authority": [
    "Vouch Source of Truth",
    "vouch.product.doctrine.md",
    "vouch.product.trust-model.md",
    "vouch.product.messaging.md",
    ".agents/docs/*",
    ".agents/contracts/*",
    ".agents/instructions/*"
  ],
  "required_invariants": [
    "Outcome follows system state.",
    "Both participants confirm inside the confirmation window before funds release.",
    "If bilateral confirmation fails, funds do not release.",
    "Stripe owns payment truth.",
    "Vouch owns workflow truth.",
    "Webhook reconciliation is idempotent.",
    "No discretionary settlement exists.",
    "No marketplace/discovery/review/messaging/dispute systems exist."
  ],
  "validation_commands": [
    {
      "command": "pnpm prisma:validate",
      "required_result": "pass"
    },
    {
      "command": "pnpm validate:contracts",
      "required_result": "pass"
    },
    {
      "command": "pnpm lint",
      "required_result": "pass"
    },
    {
      "command": "pnpm typecheck",
      "required_result": "pass"
    },
    {
      "command": "pnpm test",
      "required_result": "pass"
    },
    {
      "command": "pnpm test:e2e",
      "required_result": "pass"
    },
    {
      "command": "pnpm validate",
      "required_result": "pass"
    },
    {
      "command": "pnpm validate:all",
      "required_result": "pass"
    }
  ],
  "required_runtime_checks": [
    "Merchant can create a Vouch.",
    "Customer can accept a Vouch.",
    "Stripe creates manual-capture PaymentIntent.",
    "Both participants confirm inside window.",
    "Settlement captures only after bilateral confirmation.",
    "Late confirmation cannot release funds.",
    "Duplicate webhooks are safely deduplicated.",
    "Provider retrieve occurs before settlement mutation.",
    "No forbidden surfaces render.",
    "No manual settlement override path exists."
  ],
  "failure_conditions": [
    "Any discretionary settlement path exists.",
    "Any admin override settlement path exists.",
    "Any setup/settings/admin route surface is reintroduced.",
    "Any marketplace/discovery/review/messaging/dispute feature is introduced.",
    "Any unilateral settlement path exists.",
    "Any provider mutation occurs without provider-state retrieval."
  ],
  "final_decision": {
    "status": "not_launchable_until_all_validation_and_runtime_checks_pass"
  }
}
