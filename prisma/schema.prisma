generator client {
  provider   = "prisma-client"
  output     = "./generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

/// Vouch stores product state, provider IDs, and recovery metadata.
/// Clerk owns authentication. Stripe owns payment, balance, and payout truth.

model User {
  id          String     @id @default(cuid())
  clerkUserId String     @unique
  email       String?    @db.VarChar(320)
  phone       String?    @db.VarChar(32)
  displayName String?    @db.VarChar(120)
  status      UserStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentCustomer  PaymentCustomer?
  connectedAccount ConnectedAccount?

  merchantVouches Vouch[] @relation("VouchMerchant")
  customerVouches Vouch[] @relation("VouchCustomer")

  auditEvents AuditEvent[]

  @@index([email])
  @@index([status])
}

model PaymentCustomer {
  id     String @id @default(cuid())
  userId String @unique

  stripeCustomerId          String @unique
  lastCustomerPortalSession String?
  lastStripeEventId         String?
  syncedAt                  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

}

model ConnectedAccount {
  id     String @id @default(cuid())
  userId String @unique

  stripeAccountId String @unique

  chargesEnabled   Boolean @default(false)
  payoutsEnabled   Boolean @default(false)
  detailsSubmitted Boolean @default(false)

  requirementsCurrentlyDue  Json?
  requirementsEventuallyDue Json?
  disabledReason            String?

  lastAccountLinkId String?
  lastLoginLinkId   String?
  lastStripeEventId String?
  syncedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  payouts PayoutRecord[]

  @@index([chargesEnabled, payoutsEnabled])
}

model Vouch {
  id       String @id @default(cuid())
  publicId String @unique

  merchantId String
  customerId String?

  amountCents Int
  currency    String @default("usd") @db.VarChar(3)

  appointmentAt         DateTime
  confirmationOpensAt   DateTime
  confirmationExpiresAt DateTime

  merchantCodeHash String
  customerCodeHash String?

  status VouchStatus @default(draft)

  disclaimerAcceptedAt DateTime?

  protocolFeePaidAt DateTime?
  authorizedAt      DateTime?
  capturedAt        DateTime?
  voidedAt          DateTime?
  expiredAt         DateTime?

  archived   Boolean   @default(false)
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchant User  @relation("VouchMerchant", fields: [merchantId], references: [id], onDelete: Restrict)
  customer User? @relation("VouchCustomer", fields: [customerId], references: [id], onDelete: Restrict)

  presenceConfirmation PresenceConfirmation?
  paymentIntents       PaymentIntentRecord[]
  charges              ChargeRecord[]
  refunds              RefundRecord[]
  recoverySnapshots    VouchRecoverySnapshot[]
  webhookEvents        StripeWebhookEvent[]
  retries              OperationalRetry[]

  @@index([merchantId, archived, appointmentAt])
  @@index([customerId, archived, appointmentAt])
  @@index([status, archived])
  @@index([appointmentAt])
  @@index([expiredAt])
}

model PresenceConfirmation {
  id      String @id @default(cuid())
  vouchId String @unique

  status PresenceConfirmationStatus @default(pending)

  windowOpensAt  DateTime
  windowClosesAt DateTime

  merchantConfirmedAt DateTime?
  customerConfirmedAt DateTime?
  canCaptureAt        DateTime?
  voidedAt            DateTime?

  merchantCodeVerified Boolean @default(false)
  customerCodeVerified Boolean @default(false)

  resolutionSource PresenceResolutionSource?
  failureReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouch    Vouch                         @relation(fields: [vouchId], references: [id], onDelete: Restrict)
  attempts PresenceConfirmationAttempt[]

  @@index([status, windowClosesAt])
}

model PresenceConfirmationAttempt {
  id String @id @default(cuid())

  presenceConfirmationId String
  participantRole        ParticipantRole

  submittedAt DateTime @default(now())
  confirmedAt DateTime

  submissionMode ConfirmationSubmissionMode @default(online)

  nonce       String

  accepted       Boolean @default(false)
  rejectedReason String?

  presenceConfirmation PresenceConfirmation @relation(fields: [presenceConfirmationId], references: [id], onDelete: Restrict)

  @@unique([presenceConfirmationId, participantRole, nonce])
  @@index([presenceConfirmationId, participantRole])
  @@index([submittedAt])
}

model PaymentIntentRecord {
  id      String  @id @default(cuid())
  vouchId String?

  purpose         PaymentIntentPurpose
  participantRole ParticipantRole?

  stripePaymentIntentId   String? @unique
  stripeCheckoutSessionId String? @unique
  stripeCheckoutSessionUrl String?
  stripeCustomerId        String?
  stripeAccountId         String?

  amountCents Int
  currency    String @default("usd") @db.VarChar(3)

  status        StripePaymentIntentStatus
  captureMethod StripeCaptureMethod?
  captureBefore DateTime?

  authorizedAt DateTime?
  canceledAt   DateTime?
  failedAt     DateTime?
  succeededAt  DateTime?

  lastStripeEventId String?
  syncedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouch   Vouch?         @relation(fields: [vouchId], references: [id], onDelete: Restrict)
  charges ChargeRecord[]
  refunds RefundRecord[]

  @@index([vouchId, purpose])
  @@index([purpose, status])
  @@index([participantRole])
  @@index([stripeAccountId])
  @@index([status])
}

model ChargeRecord {
  id                    String  @id @default(cuid())
  vouchId               String?
  paymentIntentRecordId String?

  stripeChargeId             String  @unique
  stripePaymentIntentId      String?
  stripeCustomerId           String?
  stripeBalanceTransactionId String?

  amountCents Int
  currency    String @default("usd") @db.VarChar(3)

  status   StripeChargeStatus?
  captured Boolean             @default(false)
  paid     Boolean             @default(false)
  refunded Boolean             @default(false)
  disputed Boolean             @default(false)

  capturedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  vouch         Vouch?               @relation(fields: [vouchId], references: [id], onDelete: Restrict)
  paymentIntent PaymentIntentRecord? @relation(fields: [paymentIntentRecordId], references: [id], onDelete: Restrict)
  refunds       RefundRecord[]

  @@index([vouchId])
  @@index([paymentIntentRecordId])
  @@index([stripePaymentIntentId])
  @@index([stripeBalanceTransactionId])
  @@index([captured, paid])
}

model RefundRecord {
  id                    String  @id @default(cuid())
  vouchId               String?
  chargeRecordId        String?
  paymentIntentRecordId String?

  stripeRefundId        String  @unique
  stripePaymentIntentId String?
  stripeChargeId        String?

  amountCents Int
  currency    String @default("usd") @db.VarChar(3)

  reason RefundReason?
  status StripeRefundStatus

  lastStripeEventId String?
  syncedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouch         Vouch?               @relation(fields: [vouchId], references: [id], onDelete: Restrict)
  charge        ChargeRecord?        @relation(fields: [chargeRecordId], references: [id], onDelete: Restrict)
  paymentIntent PaymentIntentRecord? @relation(fields: [paymentIntentRecordId], references: [id], onDelete: Restrict)

  @@index([vouchId])
  @@index([chargeRecordId])
  @@index([paymentIntentRecordId])
  @@index([status])
}

model PayoutRecord {
  id                 String  @id @default(cuid())
  connectedAccountId String?

  stripePayoutId  String  @unique
  stripeAccountId String?

  amountCents Int
  currency    String @default("usd") @db.VarChar(3)

  status         StripePayoutStatus
  arrivalDate    DateTime?
  paidAt         DateTime?
  failedAt       DateTime?
  failureCode    String?
  failureMessage String?

  lastStripeEventId String?
  syncedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: Restrict)

  @@index([connectedAccountId, status])
  @@index([stripeAccountId])
  @@index([arrivalDate])
}

model ProviderWebhookEvent {
  id String @id @default(cuid())

  provider        WebhookProvider
  providerEventId String
  eventType       String
  status          WebhookProcessingStatus @default(received)

  payload       Json?
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  stripeEvent StripeWebhookEvent?

  @@unique([provider, providerEventId])
  @@index([provider, eventType])
  @@index([status, receivedAt])
}

model StripeWebhookEvent {
  id                     String @id @default(cuid())
  providerWebhookEventId String @unique

  stripeEventId String @unique
  eventType     String

  vouchId               String?
  paymentIntentRecordId String?
  chargeRecordId        String?
  refundRecordId        String?
  payoutRecordId        String?

  accountId String?
  livemode  Boolean @default(false)

  createdAt DateTime @default(now())

  providerWebhookEvent ProviderWebhookEvent @relation(fields: [providerWebhookEventId], references: [id], onDelete: Restrict)
  vouch                Vouch?               @relation(fields: [vouchId], references: [id], onDelete: Restrict)

  @@index([eventType, createdAt])
  @@index([vouchId])
  @@index([paymentIntentRecordId])
  @@index([chargeRecordId])
  @@index([refundRecordId])
  @@index([payoutRecordId])
  @@index([accountId])
}

model AuditEvent {
  id String @id @default(cuid())

  actorUserId String?
  actorType   AuditActorType @default(system)

  entityType String
  entityId   String
  eventName     String

  before   Json?
  after    Json?
  metadata Json?

  createdAt DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([eventName, createdAt])
}

model OperationalRetry {
  id String @id @default(cuid())

  vouchId String?

  operation OperationalRetryOperation
  status    OperationalRetryStatus    @default(pending)

  entityType String
  entityId   String

  attemptCount Int @default(0)
  maxAttempts  Int @default(24)

  nextAttemptAt DateTime?
  lastAttemptAt DateTime?
  lockedAt      DateTime?
  completedAt   DateTime?
  failedAt      DateTime?

  failureReason String?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouch Vouch? @relation(fields: [vouchId], references: [id], onDelete: Restrict)

  @@index([status, nextAttemptAt])
  @@index([operation, status])
  @@index([entityType, entityId])
  @@index([vouchId])
}

model VouchRecoverySnapshot {
  id       String @id @default(cuid())
  vouchId  String
  publicId String

  reason VouchRecoverySnapshotReason @default(created)

  merchantId String
  customerId String?

  amountCents Int
  currency    String @db.VarChar(3)

  appointmentAt         DateTime
  confirmationOpensAt   DateTime
  confirmationExpiresAt DateTime

  status VouchStatus

  protocolFeePaidAt DateTime?
  authorizedAt      DateTime?
  capturedAt        DateTime?
  voidedAt          DateTime?
  expiredAt         DateTime?
  archived          Boolean

  presenceStatus       PresenceConfirmationStatus?
  presenceCanCaptureAt DateTime?
  presenceVoidedAt     DateTime?

  merchantCodeHash String
  customerCodeHash String?

  stripePaymentIntentId      String?
  stripeCheckoutSessionId    String?
  stripeCheckoutSessionUrl   String?
  stripeChargeId             String?
  stripeBalanceTransactionId String?
  lastStripeEventId          String?

  sourceVersion Int      @default(1)
  checksumHash  String?
  createdAt     DateTime @default(now())

  vouch Vouch @relation(fields: [vouchId], references: [id], onDelete: Restrict)

  @@index([vouchId, createdAt])
  @@index([publicId])
  @@index([reason])
  @@index([createdAt])
}

enum UserStatus {
  active
  suspended
  disabled
}

enum ParticipantRole {
  merchant
  customer
}

enum VouchStatus {
  draft
  protocol_fee_paid
  authorized
  can_capture
  captured
  expired
  archived
}

enum PresenceConfirmationStatus {
  pending
  merchant_confirmed
  customer_confirmed
  can_capture
  void
  auto_void
}

enum ConfirmationSubmissionMode {
  online
}

enum PresenceResolutionSource {
  online
  auto_void
}

enum PaymentIntentPurpose {
  merchant_protocol_fee
  customer_deposit_authorization
}

enum StripePaymentIntentStatus {
  requires_payment_method
  requires_confirmation
  requires_action
  processing
  requires_capture
  canceled
  succeeded
}

enum StripeCaptureMethod {
  automatic
  manual
}

enum StripeChargeStatus {
  succeeded
  pending
  failed
}

enum RefundReason {
  duplicate
  fraudulent
  requested_by_customer
  expired_uncaptured_authorization
  provider_reconciliation
}

enum StripeRefundStatus {
  pending
  requires_action
  succeeded
  failed
  canceled
}

enum StripePayoutStatus {
  pending
  in_transit
  paid
  failed
  canceled
}

enum WebhookProvider {
  stripe
  clerk
}

enum WebhookProcessingStatus {
  received
  processing
  processed
  ignored
  failed
}

enum AuditActorType {
  user
  system
  clerk
  stripe
}

enum OperationalRetryOperation {
  reconcile_payment_intent
}

enum OperationalRetryStatus {
  pending
  processing
  succeeded
  failed
  abandoned
}

enum VouchRecoverySnapshotReason {
  created
  before_capture
  presence_auto_void
  webhook_reconciliation
  provider_reconciliation
}
