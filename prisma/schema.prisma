generator client {
  provider   = "prisma-client"
  output     = "./generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id @default(cuid())
  clerkUserId String @unique

  primaryEmailAddressId String?
  email                 String? @db.VarChar(320)
  firstName             String? @db.VarChar(120)
  lastName              String? @db.VarChar(120)
  imageUrl              String?

  passwordEnabled Boolean @default(true)
  deleted         Boolean @default(false)

  clerkCreatedAt DateTime?
  clerkUpdatedAt DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  emailAddresses ClerkEmailAddress[]
  sessions       ClerkSession[]
  stripeAccount  StripeConnectedAccount?

  @@index([primaryEmailAddressId])
  @@index([email])
  @@index([deleted])
  @@map("users")
}

model ClerkEmailAddress {
  id          String @id
  clerkUserId String?

  emailAddress String @db.VarChar(320)
  verification Json?
  linkedTo      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: SetNull)

  @@index([clerkUserId])
  @@index([emailAddress])
  @@map("clerk_email_addresses")
}

model ClerkSession {
  id          String @id
  clerkUserId String?

  status        String
  lastEventType String

  abandonAt DateTime?
  expireAt  DateTime?
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  endedAt   DateTime?
  removedAt DateTime?
  revokedAt DateTime?

  user User? @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: SetNull)

  @@index([clerkUserId])
  @@index([status])
  @@index([lastEventType])
  @@map("clerk_sessions")
}

model StripeConnectedAccount {
  id     String @id @default(cuid())
  userId String @unique

  stripeAccountId String @unique

  object          String @default("account")
  type            String?
  country         String? @db.VarChar(2)
  email           String? @db.VarChar(320)
  defaultCurrency String? @db.VarChar(3)
  livemode        Boolean @default(false)

  chargesEnabled   Boolean @default(false)
  payoutsEnabled   Boolean @default(false)
  detailsSubmitted Boolean @default(false)

  businessType        String?
  businessProfile     Json?
  capabilities        Json?
  requirements        Json?
  futureRequirements  Json?
  controller          Json?
  settings            Json?
  tosAcceptance       Json?
  metadata            Json?

  disabledReason String?
  currentDeadline DateTime?
  stripeCreatedAt DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  accountLinks    StripeAccountLink[]
  applicationFees StripeApplicationFee[]

  @@index([stripeAccountId])
  @@index([chargesEnabled])
  @@index([payoutsEnabled])
  @@index([detailsSubmitted])
  @@index([disabledReason])
  @@index([lastSyncedAt])
  @@map("stripe_connected_accounts")
}

model StripeAccountLink {
  id String @id @default(cuid())

  stripeAccountId String

  object      String
  useCaseType String?
  type        String?
  livemode    Boolean @default(false)

  stripeCreatedAt DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  connectedAccount StripeConnectedAccount @relation(fields: [stripeAccountId], references: [stripeAccountId], onDelete: Restrict)

  @@index([stripeAccountId])
  @@index([object])
  @@index([useCaseType])
  @@index([type])
  @@index([expiresAt])
  @@map("stripe_account_links")
}

model StripeApplicationFee {
  id String @id @default(cuid())

  stripeApplicationFeeId String @unique
  stripeAccountId        String

  object                 String @default("application_fee")
  amount                 Int
  amountRefunded         Int    @default(0)
  application            String?
  balanceTransaction     String?
  charge                 String?
  currency               String @db.VarChar(3)
  feeSource              Json?
  livemode               Boolean @default(false)
  originatingTransaction String?
  refunded               Boolean @default(false)
  refunds                Json?

  stripeCreatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connectedAccount StripeConnectedAccount @relation(fields: [stripeAccountId], references: [stripeAccountId], onDelete: Restrict)

  @@index([stripeAccountId])
  @@index([balanceTransaction])
  @@index([charge])
  @@index([currency])
  @@index([livemode])
  @@index([refunded])
  @@index([stripeCreatedAt])
  @@map("stripe_application_fees")
}

model WebhookEvent {
  id String @id @default(cuid())

  provider        String
  providerEventId String
  eventType       String

  processed Boolean @default(false)
  ignored   Boolean @default(false)

  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error        String?
  data         Json?

  @@unique([provider, providerEventId])
  @@index([provider])
  @@index([eventType])
  @@index([processed])
  @@index([ignored])
  @@index([receivedAt])
  @@map("webhook_events")
}
